{
    "name": "yuges-code/laravel-commentable",
    "description": "Package for easily attaching comments to Laravel eloquent models",
    "license": "MIT",
    "keywords": [
        "yuges",
        "laravel",
        "comment",
        "comments",
        "commentable",
        "laravel-commentable"
    ],
    "authors": [
        {
            "name": "Georgy",
            "email": "goshasafonov@yandex.ru"
        }
    ],
    "require": {
        "php": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "Yuges\\Commentable\\": "src"
        }
    },
    "minimum-stability": "dev",
    "extra": {
        "laravel": {
            "providers": [
                "Yuges\\Commentable\\Providers\\CommentableServiceProvider"
            ]
        }
    }
}
